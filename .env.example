# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, so secrets never get committed.

# Formspree endpoint that all site forms (book a demo, contact, partners, etc.)
# submit to. Create a form at https://formspree.io and paste its endpoint here.
# Exposed to the browser (NEXT_PUBLIC_ prefix) because the form posts client-side.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
