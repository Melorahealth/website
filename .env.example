# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, so secrets never get committed.

# Formspree endpoint that general site forms (contact, partners, gift, etc.)
# submit to. Create a form at https://formspree.io and paste its endpoint here.
# Exposed to the browser (NEXT_PUBLIC_ prefix) because the form posts client-side.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Separate Formspree form for the Book a Demo page, so demo requests land in
# their own inbox. If unset, the Book a Demo form falls back to the general
# endpoint above.
NEXT_PUBLIC_FORMSPREE_DEMO_ENDPOINT=https://formspree.io/f/your-demo-form-id
